---
/**
 * 論文カードコンポーネント
 *
 * タイトル・著者・カテゴリ・スコア・星UI・abstractアコーディオンを表示する。
 * 星クリックで POST /api/rate を呼び出す。
 */
import type { Paper } from "../lib/types";

interface Props {
  paper: Paper;
  initialRating: number;
}

const { paper, initialRating } = Astro.props;

const scorePercent = Math.round(paper.score * 100);
const firstCategory = paper.categories[0] ?? "";
---

<article class="paper-card" data-paper-id={paper.id}>
  <header class="paper-header">
    <h2 class="paper-title">
      <a href={paper.url} target="_blank" rel="noopener noreferrer">
        {paper.title}
      </a>
    </h2>
    <div class="paper-meta">
      <span class="authors"
        >{paper.authors.slice(0, 3).join(", ")}{
          paper.authors.length > 3 ? " et al." : ""
        }</span
      >
      <span class="sep">·</span>
      <span class="category">{firstCategory}</span>
      <span class="sep">·</span>
      <span class="score">score {scorePercent}%</span>
    </div>
  </header>

  <div class="paper-actions">
    <p class="submitted">{paper.submitted}</p>
    <div
      class="star-rating"
      data-paper-id={paper.id}
      data-title={paper.title}
      data-abstract={paper.abstract}
      data-rating={initialRating}
    >
      {
        [1, 2, 3].map((n) => (
          <button
            class={`star ${n <= initialRating ? "active" : ""}`}
            data-value={n}
            aria-label={`${n} star`}
          >
            ★
          </button>
        ))
      }
    </div>

    <a
      class="pdf-link"
      href={`https://arxiv.org/pdf/${paper.id}`}
      target="_blank"
      rel="noopener noreferrer"
    >
      PDF
    </a>

    {
      paper.github_url && (
        <a
          class="github-link"
          href={paper.github_url}
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub
        </a>
      )
    }
  </div>

  <details class="abstract-details">
    <summary>abstract</summary>
    <p class="abstract-text">{paper.abstract}</p>
  </details>

  <div class="abstract-popup">
    <p>{paper.abstract}</p>
  </div>
</article>

<style>
  .paper-card {
    border-bottom: 1px solid #e8e8e5;
    padding: 1rem 0;
    margin-bottom: 0;
    background: transparent;
    position: relative;
  }

  .paper-card:first-child {
    padding-top: 0;
  }

  /* ─── Abstract Popup ─── */
  .abstract-popup {
    position: absolute;
    left: 0;
    right: auto;
    top: 100%;
    z-index: 100;
    width: min(620px, calc(100vw - 2rem));
    background: #fff;
    border: 1px solid #ddd;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12), 0 2px 6px rgba(0, 0, 0, 0.06);
    padding: 1rem 1.25rem;
    max-height: 360px;
    overflow-y: auto;
    scrollbar-width: thin;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s ease, visibility 0.15s ease;
    pointer-events: none;
  }

  .abstract-popup p {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.7;
    color: #333;
  }

  .paper-card:hover .abstract-popup {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition-delay: 0.3s;
  }

  /* タブレット・モバイルでは details アコーディオンで代用するためポップアップを非表示 */
  @media (max-width: 1024px) {
    .abstract-popup {
      display: none;
    }
  }

  .paper-title {
    font-size: 1.02rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
    line-height: 1.35;
    letter-spacing: -0.015em;
  }

  .paper-title a {
    color: #111;
    text-decoration: none;
  }

  .paper-title a:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
  }

  .paper-meta {
    font-size: 0.75rem;
    color: #888;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-bottom: 0.45rem;
  }

  .authors {
    color: #555;
  }

  .sep {
    color: #ccc;
  }

  .category {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
  }

  .score {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.78rem;
    font-weight: 600;
    color: #16713a;
    background: #f0faf3;
    padding: 0 0.3rem;
    margin-left: 0.1rem;
  }

  .paper-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.35rem;
  }

  .submitted {
    font-size: 0.72rem;
    color: #aaa;
    margin: 0;
    font-family: 'IBM Plex Mono', monospace;
  }

  .star-rating {
    display: flex;
    gap: 1px;
  }

  .star {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.2rem;
    color: #ddd;
    padding: 0;
    line-height: 1;
    transition: color 0.1s;
  }

  .star.active,
  .star:hover {
    color: #b8860b;
  }

  .pdf-link,
  .github-link {
    font-size: 0.72rem;
    font-family: 'IBM Plex Mono', monospace;
    text-decoration: none;
    color: #bbb;
    transition: color 0.15s;
  }

  .pdf-link:hover {
    color: #b91c1c;
  }

  .github-link:hover {
    color: #1a1a1a;
  }

  .abstract-details summary {
    font-size: 0.72rem;
    font-family: 'IBM Plex Mono', monospace;
    color: #bbb;
    cursor: pointer;
    user-select: none;
  }

  .abstract-details summary:hover {
    color: #555;
  }

  .abstract-text {
    margin-top: 0.5rem;
    font-size: 0.84rem;
    line-height: 1.65;
    color: #444;
    white-space: pre-wrap;
  }
</style>

<script>
  // ページロード時にKVの最新評価でUIを初期化
  document.addEventListener("DOMContentLoaded", async () => {
    try {
      const res = await fetch("/api/ratings");
      if (!res.ok) return;
      const data = (await res.json()) as {
        ratings: { paper_id: string; rating: number }[];
      };
      const ratingMap = new Map(
        data.ratings.map((r) => [r.paper_id, r.rating]),
      );

      document
        .querySelectorAll<HTMLElement>(".star-rating")
        .forEach((container) => {
          const paperId = container.dataset.paperId;
          if (!paperId) return;
          const rating = ratingMap.get(paperId) ?? 0;
          updateStars(container, rating);
          container.dataset.rating = String(rating);
        });
    } catch {
      // フォールバック: 静的HTMLの初期値をそのまま使用
    }
  });

  document.addEventListener("click", async (e) => {
    const btn = (e.target as Element).closest(".star");
    if (!btn) return;

    const container = btn.closest(".star-rating") as HTMLElement | null;
    if (!container) return;

    const rating = Number((btn as HTMLElement).dataset.value);
    const paperId = container.dataset.paperId;
    const title = container.dataset.title;
    const abstract = container.dataset.abstract;

    updateStars(container, rating);

    try {
      const res = await fetch("/api/rate", {
        method: "POST",
        credentials: "include",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ paper_id: paperId, title, abstract, rating }),
      });

      if (res.status === 401 || res.status === 403) {
        window.location.href = `/api/rate?next=${encodeURIComponent(window.location.href)}`;
        return;
      }

      if (!res.ok) {
        console.error("[rate] API error:", res.status);
        updateStars(container, Number(container.dataset.rating));
      } else {
        container.dataset.rating = String(rating);
      }
    } catch (err) {
      // CORS エラー（未認証時のリダイレクトによる）→ Access 認証後に元のページへ戻る
      window.location.href = `/api/rate?next=${encodeURIComponent(window.location.href)}`;
    }
  });

  function updateStars(container: HTMLElement, rating: number) {
    container.querySelectorAll(".star").forEach((star) => {
      const val = Number((star as HTMLElement).dataset.value);
      star.classList.toggle("active", val <= rating);
    });
  }
</script>
