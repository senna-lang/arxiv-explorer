---
/**
 * おすすめ論文セクション
 *
 * recommendations.jsonを読み込み、近傍クラスタ名とおすすめ論文を表示する。
 * データがない場合はセクション自体を非表示にする。
 */
import { getRecommendations } from "../lib/data";

const data = getRecommendations();
if (!data || data.recommendations.length === 0) {
  // データなし → 何も表示しない
}
---

{data && data.recommendations.length > 0 && (
  <section class="recommend-section">
    <h2 class="section-title">Recommended</h2>

    <div class="top-clusters">
      <span class="clusters-label">top clusters:</span>
      {data.top_clusters.map((c) => (
        <span class="cluster-tag">
          {c.label} ({Math.round(c.score * 100)}%)
        </span>
      ))}
    </div>

    <div class="recommend-list">
      {data.recommendations.map((rec) => (
        <article class="recommend-card">
          <div class="rec-meta">
            <span class="matched-cluster">{rec.matched_cluster}</span>
            <span class="match-score">match {Math.round(rec.match_score * 100)}%</span>
          </div>
          <h3 class="rec-title">
            <a href={rec.url} target="_blank" rel="noopener noreferrer">
              {rec.title}
            </a>
          </h3>
          <div class="rec-actions">
            <p class="rec-submitted">{rec.submitted}</p>
            <a
              class="rec-pdf-link"
              href={`https://arxiv.org/pdf/${rec.id}`}
              target="_blank"
              rel="noopener noreferrer"
            >PDF</a>
            <div
              class="star-rating"
              data-paper-id={rec.id}
              data-title={rec.title}
              data-abstract={rec.abstract}
              data-rating="0"
            >
              {[1, 2, 3].map((n) => (
                <button class="star" data-value={n} aria-label={`${n} star`}>★</button>
              ))}
            </div>
          </div>
          <details class="rec-abstract">
            <summary>abstract</summary>
            <p>{rec.abstract}</p>
          </details>
        </article>
      ))}
    </div>
  </section>
)}

<style>
  .recommend-section {
    margin-top: 2rem;
    border-top: 1px solid #e0e0dc;
    padding-top: 1rem;
  }

  .section-title {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #111;
    margin: 0 0 0.6rem;
  }

  .top-clusters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem;
    margin-bottom: 1rem;
    font-size: 0.75rem;
  }

  .clusters-label {
    color: #999;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
  }

  .cluster-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    color: #555;
    border: 1px solid #e0e0dc;
    padding: 0.1rem 0.4rem;
  }

  .recommend-card {
    border-bottom: 1px solid #e0e0dc;
    padding: 0.7rem 0;
    margin-bottom: 0;
    background: transparent;
  }

  .rec-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.7rem;
    font-family: 'IBM Plex Mono', monospace;
    margin-bottom: 0.3rem;
  }

  .matched-cluster {
    color: #555;
    font-weight: 500;
  }

  .match-score {
    color: #16713a;
  }

  .rec-title {
    font-size: 0.92rem;
    font-weight: 600;
    margin: 0 0 0.3rem;
    letter-spacing: -0.01em;
  }

  .rec-title a {
    color: #1a1a1a;
    text-decoration: none;
  }

  .rec-title a:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
  }

  .rec-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
  }

  .rec-submitted {
    font-size: 0.72rem;
    font-family: 'IBM Plex Mono', monospace;
    color: #999;
    margin: 0;
  }

  .rec-pdf-link {
    font-size: 0.7rem;
    font-family: 'IBM Plex Mono', monospace;
    color: #999;
    text-decoration: none;
  }

  .rec-pdf-link:hover { color: #b91c1c; }

  .rec-actions .star-rating {
    display: flex;
    gap: 1px;
  }

  .rec-actions .star {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.1rem;
    color: #ddd;
    padding: 0;
    line-height: 1;
    transition: color 0.1s;
  }

  .rec-actions .star.active,
  .rec-actions .star:hover {
    color: #b8860b;
  }

  .rec-abstract summary {
    font-size: 0.72rem;
    font-family: 'IBM Plex Mono', monospace;
    color: #999;
    cursor: pointer;
  }

  .rec-abstract summary:hover { color: #555; }

  .rec-abstract p {
    font-size: 0.82rem;
    line-height: 1.6;
    margin-top: 0.5rem;
    color: #555;
  }
</style>
