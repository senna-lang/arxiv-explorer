---
/**
 * 日付別論文一覧ページ
 *
 * getStaticPaths で利用可能な全日付を静的生成する。
 * data/YYYYMMDD.json を読み込み、論文カードを score 降順で表示する。
 * 前日/翌日ナビゲーション付き。
 */
import PaperCard from "../components/PaperCard.astro";
import RecommendSection from "../components/RecommendSection.astro";
import { getAvailableDates, getPapersForDate, getRatingMap } from "../lib/data";

export function getStaticPaths() {
  const files = import.meta.glob("/data/????????.json");
  const dates = Object.keys(files)
    .map((f) => f.replace("/data/", "").replace(".json", ""))
    .sort();
  return dates.map((date) => ({ params: { date } }));
}

const { date } = Astro.params;

const papers = getPapersForDate(date);
const ratingMap = getRatingMap();
const dates = getAvailableDates();
const idx = dates.indexOf(date);
const prevDate = idx > 0 ? dates[idx - 1] : null;
const nextDate = idx < dates.length - 1 ? dates[idx + 1] : null;

const displayDate = `${date.slice(0, 4)}-${date.slice(4, 6)}-${date.slice(6, 8)}`;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>arXiv新聞 {displayDate}</title>
    <style>
      * { box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        max-width: 800px;
        margin: 0 auto;
        padding: 1rem;
        background: #f8f8f8;
        color: #222;
      }
      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 0.5rem;
      }
      h1 { font-size: 1.4rem; margin: 0; }
      .nav { display: flex; gap: 0.75rem; }
      .nav a {
        font-size: 0.88rem;
        color: #1a0dab;
        text-decoration: none;
        padding: 0.2rem 0.5rem;
        border: 1px solid #ccc;
        border-radius: 4px;
      }
      .nav a:hover { background: #e8e8e8; }
      .nav span {
        font-size: 0.88rem;
        color: #aaa;
        padding: 0.2rem 0.5rem;
      }
      .count {
        font-size: 0.82rem;
        color: #666;
        margin-bottom: 1rem;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>📰 arXiv新聞 {displayDate}</h1>
      <nav class="nav">
        {prevDate
          ? <a href={`/${prevDate}`}>← 前日</a>
          : <span>← 前日</span>
        }
        {nextDate
          ? <a href={`/${nextDate}`}>翌日 →</a>
          : <span>翌日 →</span>
        }
        <a href="/map">🗺 地図</a>
      </nav>
    </header>

    <p class="count">{papers.length} 件</p>

    {papers.map((paper) => (
      <PaperCard paper={paper} initialRating={ratingMap.get(paper.id) ?? 0} />
    ))}

    <RecommendSection />
  </body>
</html>
