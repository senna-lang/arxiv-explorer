---
/**
 * arXiv論文ダッシュボードページ
 *
 * deck.gl ベースのインタラクティブ地図 + 詳細パネル + いいね一覧。
 * map.json の座標データと日次JSONの論文詳細をビルド時にマージして
 * React アイランドに渡す。
 */
import MainLayout from "../layouts/MainLayout.astro";
import { Dashboard } from "../components/dashboard/Dashboard";
import { buildDashboardPapers } from "../lib/map-data";
import type { MapData, RatingsData } from "../lib/types";
import { readFileSync } from "node:fs";
import { join } from "node:path";

// Vite の制約: import.meta.glob は各ページファイルで直接呼ぶ必要がある
const mapGlob = import.meta.glob("/data/map.json", { eager: true });
const dailyGlob = import.meta.glob("/data/????????.json", { eager: true });

const mapMod = Object.values(mapGlob)[0] as { default?: MapData } & MapData;
const mapData = (mapMod?.default ?? mapMod) as MapData;

const papers = buildDashboardPapers(mapData, dailyGlob);
const clusters = mapData.clusters;

// ビルド時にratings.jsonを読んでフォールバックとして渡す
let initialRatings: RatingsData["ratings"] = [];
try {
  const raw = readFileSync(join(process.cwd(), "data/ratings.json"), "utf-8");
  initialRatings = (JSON.parse(raw) as RatingsData).ratings;
} catch {
  // ratings.json がなくても動作する
}
---

<MainLayout title="arxiv compass">
  <style is:global>
    body {
      background: #fff !important;
      color: #1a1a1a !important;
      padding: 0.6rem 0.75rem !important;
    }
    .dashboard-header {
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
      margin-bottom: 0.35rem;
    }
    .dashboard-header h1 {
      font-family: 'IBM Plex Sans', -apple-system, sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      margin: 0;
      color: #1a1a1a;
      letter-spacing: -0.01em;
    }
    .dashboard-header .back {
      font-size: 0.72rem;
      color: #999;
      text-decoration: none;
      font-family: 'IBM Plex Mono', monospace;
    }
    .dashboard-header .back:hover {
      color: #555;
    }
    @media (max-width: 767px) {
      body {
        padding: 0.3rem 0.4rem !important;
      }
      .dashboard-header {
        margin-bottom: 0.2rem;
      }
      .dashboard-header h1 {
        font-size: 0.8rem;
      }
    }
  </style>

  <header class="dashboard-header">
    <h1>arxiv compass</h1>
    <a class="back" href="/">← daily</a>
  </header>

  <Dashboard
    client:only="react"
    papers={papers}
    clusters={clusters}
    initialRatings={initialRatings}
  />
</MainLayout>
