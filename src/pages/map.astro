---
/**
 * arXiv論文地図ページ
 *
 * datamapplotが生成した map.html を iframe で表示する。
 * 近傍クラスタのハイライトは recommend.py が map.html を再生成することで反映される。
 */
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="arXiv 論文地図">
  <style slot="head">
    header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }
    h1 { font-size: 1.3rem; margin: 0; }
    .back { font-size: 0.85rem; color: #1a0dab; text-decoration: none; }
    .back:hover { text-decoration: underline; }
    .map-frame {
      width: 100%;
      height: 80vh;
      border: 1px solid #ddd;
      border-radius: 8px;
      background: #fff;
    }
    .no-data {
      text-align: center;
      padding: 3rem;
      color: #888;
    }
  </style>

  <header>
    <h1>🗺 arXiv 論文地図</h1>
    <a class="back" href="/">← 新聞に戻る</a>
  </header>

  <iframe
    class="map-frame"
    src="/map.html"
    title="arXiv Paper Map"
    sandbox="allow-scripts allow-same-origin"
  ></iframe>
</MainLayout>
